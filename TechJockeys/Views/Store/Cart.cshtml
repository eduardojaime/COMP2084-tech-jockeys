@model IEnumerable<CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<h1>My Shopping Cart</h1>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CustomerId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Product)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.CustomerId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Product.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Quantity)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    <a 
                        class="btn btn-danger" 
                        asp-controller="Store" 
                        asp-action="RemoveFromCart"
                        asp-route-id="@item.CartItemId"> X </a>
                </td>
            </tr>    
        }
        <tr>
            <td colspan="2"></td>
            <td style="text-align: right">Total Amount:</td>
            <td style="text-align: left">@ViewBag.TotalAmount.ToString("C")</td>
            <td></td>
        </tr>
    </tbody>
</table>

<div class="col-12 mb-auto text-info">
    <a class="btn btn-info" asp-controller="Store" asp-action="Index">Continue Shopping</a>
    <a class="btn btn-success" asp-controller="Store" asp-action="Checkout">Proceed to Checkout</a>
</div>